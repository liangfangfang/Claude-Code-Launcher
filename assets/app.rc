// Windows resource file for Claude Code Launcher
#include <windows.h>

// Icon
APP_ICON ICON "icon.ico"

// Version info
VS_VERSION_INFO VERSIONINFO
FILEVERSION 2,1,0,0
PRODUCTVERSION 2,1,0,0
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
FILEFLAGS 0x0L
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904B0"
        BEGIN
            VALUE "CompanyName", "akchth"
            VALUE "FileDescription", "Claude Code Launcher"
            VALUE "FileVersion", "2.1.0.0"
            VALUE "InternalName", "claude-launcher"
            VALUE "LegalCopyright", "Copyright (c) 2026 akchth"
            VALUE "OriginalFilename", "claude-launcher.exe"
            VALUE "ProductName", "Claude Code Launcher"
            VALUE "ProductVersion", "2.1.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
